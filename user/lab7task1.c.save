#include <kernel/types.h>
#include <user/user.h>

// el function elly el threads hat-run feha
void *worker(void *arg) {

    /*
        arg howa "void pointer" (sando' msh maktoub aleeh no3o)
        (int *)arg -> ehna kda ben'ol lel compiler: etaamel ma3 el sandou' da enno pointer le int
	*(int *)arg -> el `*` de yaani "rouh hat el value elly gowa el address da"
    */

    int tid = *(int *)arg;

    printf("Thread %d is running\n", tid);

    // return NULL -> aashan ne'fel el thread de lewahdo mesh el program kolo
    exit(0);
}

int main() {
    int num_threads = 5;
    pthread_t threads[num_threads];
    int thread_ids[num_];

    for (int i =0; i < num_threads; i++) {
        thread_ids[i] = i;

	printf("Main: creating thread %d\n", i);


	/*
	    pthreads_create(address el thread,NULL(default settings),Function ely hat-run,arg rly rayeh lel function)
	*/
	pthread_create(&threads[i], NULL, worker, &thread_ids[i]);
    }


    for (int i = 0; i < num_threads; i++) {
	pthread_join(threads[i], NULL);
    }

    printf("Main thread finished.\n");
    return 0;
}
